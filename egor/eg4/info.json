{
  "series_id": "hpytt0202605",
  "year": 2026,
  "sport": "f1",
  "quality": "4K",
  
  "record_processing": {
    "input_file": "../f1db.csv",
    "output_directory": ".",
    "output_filename_template": "{year}{round}{quality}.csv",

    "filters": {
      "case_insensitive": true,
      "include": [
        "\\bF1\\b|Formula.?1|Formula.?One"
      ],
      "exclude": [
        "\\bIndy\\b",
        "\\bIndyCar\\b",
        "\\bIndy.NXT\\b",
        "\\bNASCAR\\b",
        "\\bMotoGP\\b",
        "\\bWEC\\b"
      ]
    },
    
    "patterns": {
      "round": {
        "regex": "(R\\d+|x\\d+|Round\\s?\\d+)",
        "case_insensitive": true,
        "normalize_format": "r{num:02d}"
      },
      "resolution": {
        "regex": "(1080[Pp]|SD|4K|2160[Pp]|FHD|720[Pp]|UHD)",
        "case_insensitive": true,
        "mappings": {
          "1080P": "FHD",
          "FHD": "FHD",
          "SD": "SD",
          "720P": "SD",
          "2160P": "4K",
          "4K": "4K",
          "UHD": "4K"
        }
      },
      "year": {
        "regex": "(\\d{4})",
        "case_insensitive": false
      }
    },

    "columns": {
      "description_index": 0,
      "guid_index": 1,
      "resolution_fallback_index": 1
    },
    
    "deduplication": {
      "enabled": true,
      "key_column_index": 1
    }
  },
  
  "csv_processing": {
    "input_file_pattern": "^2.*\\.csv$",
    "date_column_index": 3,
    "date_format": "%d %b %Y %H:%M:%S %z",
    "torrent_name_column_index": 0,
    "magnet_link_column_index": 1,
    "infohash_pattern": "btih:([a-zA-Z0-9]+)",
    "output_extensions": {
      "active": ".csv",
      "archive": ".archive",
      "old": ".old"
    },
    "output_columns": ["torrent_name", "infohash", "magnet_link"],
    "create_subdirectory": true,
    "skip_if_exists": [".csv", ".archive", ".old"]
  },
  
  "file_retention": {
    "keep_latest_rounds": 3,
    "directory_pattern": "{year}r(\\d+){quality}",
    "backup_extension": ".old"
  },

  "parsing": {
    "torrent_name": {
      "round_pattern": "R(\\d+)",
      "grand_prix_pattern": "R\\d+[.\\s]+([A-Za-z][A-Za-z.\\s]+?Grand[.\\s]Prix)(?:[.\\s]|$)",
      "fallback_gp_pattern": "R\\d+[.\\s]+([A-Za-z][A-Za-z.\\s]+?)(?:\\.Sky|\\.F1TV|\\.UHD|\\.2160|\\.1080|\\.720|\\s(?:Sky|F1TV|UHD)|$)"
    },
    "filename": {
      "title_pattern": "^\\d+\\.F1\\.\\d{4}\\.R\\d+\\..+?\\.Grand\\.Prix\\.(.+?)(?:\\.Sky|\\.F1TV|\\.UHD|\\.2160p|\\.1080p|\\.720p|\\.mkv|\\.mp4)",
      "fallback_title_pattern": "^\\d+\\.(.+?)\\.(mkv|mp4)$"
    },
    "session_types": [],
    "quality_markers": [],
    "title_format": "{title} - {grand_prix}",
    "title_cleanup": {
      "replace_dots": true,
      "replace_underscores": true,
      "title_case": false,
      "remove_common_suffixes": true
    }
  },
  
  "data_paths": {
    "config_file": "../../data/f1_config.json",
    "input_csv": "content.csv",
    "output_csv": "6processed.csv",
    "info_json": "info.json"
  },
  
  "column_mapping": {
    "torrent_name": ["torrent file name", "torrent_name", "torrent", "name"],
    "filename": ["filename within torrent", "filename", "file", "path"],
    "infohash": ["infohash", "hash", "info_hash"],
    "file_index": ["file index", "file_index", "fileindex", "index", "idx"],
    "filesize": ["filesize_gb", "filesize", "size", "file_size", "size_gb"]
  },
  
  "output": {
    "incremental": true,
    "include_filesize": true,
    "include_quality": true,
    "sort_by": ["season", "episode"],
    "deduplicate": true
  },
  
  "peer_settings": {
    "max_peers_to_try": 100,
    "peer_connect_timeout": 5,
    "peer_metadata_timeout": 30
  },
  "tracker_settings": {
    "tracker_timeout": 10,
    "dht_timeout": 20
  },
  "debug": {
    "verbose": true,
    "debug_peers": true,
    "log_skipped_rows": false
  }
}
